# Auto-detect text/binary and normalize line endings on commit.
* text=auto eol=lf

# Force CRLF for Windows-only files
# PowerShell 5.1 default-decodes scripts as system ANSI (GBK on zh-CN),
# garbling UTF-8 multibyte chars. UTF-8 BOM forces correct decoding.
*.ps1   text eol=crlf working-tree-encoding=UTF-8-BOM
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary
*.xls   binary
*.xlsx  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.db    binary
