# Auto-detect text/binary and normalize line endings on commit.
* text=auto eol=lf

# Force CRLF for Windows-only files
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary
*.xls   binary
*.xlsx  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.db    binary
